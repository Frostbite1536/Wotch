{
  "name": "wotch",
  "version": "1.0.0",
  "description": "Wotch — the notch, for those without. A floating terminal for Claude Code (Windows, Linux, macOS)",
  "author": "Frostbite1536 <frostbite1536@users.noreply.github.com>",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac",
    "postinstall": "electron-rebuild"
  },
  "build": {
    "appId": "com.wotch.app",
    "productName": "Wotch",
    "icon": "assets/icon.png",
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": "dmg",
      "minimumSystemVersion": "13.0"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Frostbite1536",
        "repo": "Wotch"
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "src/mcp-server.js",
        "to": "mcp-server.js"
      }
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.0.0",
    "node-pty": "^1.0.0",
    "ssh2": "^1.17.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-rebuild": "^3.2.9"
  }
}
